{
  "name": "guildbotics-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,html}\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "duplicates": "jscpd --config jscpd.config.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "quality": "npm run format:check && npm run lint && npm run typecheck && npm run duplicates && npm run test",
    "tauri": "tauri"
  },
  "dependencies": {
    "@mantine/core": "^7.17.8",
    "@mantine/form": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@mantine/notifications": "^7.17.8",
    "@tanstack/react-query": "^5.80.0",
    "@tauri-apps/api": "2.5.0",
    "@tauri-apps/plugin-dialog": "2.2.0",
    "@tauri-apps/plugin-shell": "2.2.1",
    "i18next": "^26.3.0",
    "lucide-react": "^0.468.0",
    "mantine-form-zod-resolver": "^1.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.30.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "2.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jscpd": "^4.2.4",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true
  }
}
